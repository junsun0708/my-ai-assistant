# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Target channel (channel name or ID)
TARGET_CHANNEL=my-ai

# AI Provider Configuration
# Default: "claude" or "openai"
DEFAULT_PROVIDER=claude

# Anthropic (Claude) Configuration
# Option 1: Set API key directly
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# Option 2: Leave empty to use Claude CLI subscription
# (requires `claude` CLI installed and authenticated)

# Anthropic model (claude-sonnet-4-20250514, claude-3-5-sonnet-20241022, etc.)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI Configuration (REQUIRED - no subscription option)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI model (gpt-4o-mini, gpt-4o, gpt-3.5-turbo, etc.)
OPENAI_MODEL=gpt-4o-mini

# Tavily Web Search Configuration (optional but recommended)
TAVILY_API_KEY=tvly-your-tavily-key-here
WEB_SEARCH_ENABLED=true

# Behavior Settings
MAX_CONVERSATION_HISTORY=20
STREAMING_ENABLED=true
THINKING_INDICATOR=true
